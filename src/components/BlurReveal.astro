---
interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
---

<div class="blur-reveal" data-revealed="false">
  <img src={src} alt={alt} class="blur-reveal-img" loading="lazy" />
  <span class="blur-reveal-hint">Tap to reveal</span>
</div>

<style>
  .blur-reveal {
    position: relative;
    max-width: 400px;
    margin: 2rem auto;
    cursor: pointer;
  }
  
  .blur-reveal-img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    filter: blur(15px);
    transition: filter 0.4s ease;
  }
  
  .blur-reveal[data-revealed="true"] .blur-reveal-img {
    filter: none;
  }
  
  .blur-reveal[data-revealed="true"] {
    cursor: default;
  }
  
  .blur-reveal-hint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    text-shadow: 0 1px 3px rgba(0,0,0,0.6);
    pointer-events: none;
  }
  
  .blur-reveal[data-revealed="true"] .blur-reveal-hint {
    display: none;
  }
</style>

<script>
  document.querySelectorAll('.blur-reveal').forEach(el => {
    el.addEventListener('click', () => {
      el.setAttribute('data-revealed', 'true');
    });
  });
</script>
