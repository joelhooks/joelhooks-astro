---
import MuxVideoReact from './MuxVideoReact.tsx';

interface Props {
  playbackId: string;
  title?: string;
  aspectRatio?: string;
  loop?: boolean;
}

const { playbackId, title, aspectRatio, loop } = Astro.props;
---

<MuxVideoReact client:load playbackId={playbackId} title={title} aspectRatio={aspectRatio} loop={loop} />
