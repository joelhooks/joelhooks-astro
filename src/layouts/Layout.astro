---
import {SEO} from "astro-seo"
export interface Props {
  title: string
}

const {title} = Astro.props
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="me" href="https://hachyderm.io/@joelhooks" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title="articles written by Joel Hooks"
      description="digital garden focused on teaching, technology, and the web"
    />
    <script
      type="text/partytown"
      src="https://cdn.usefathom.com/script.js"
      data-site="OWTIMPTX"
    ></script>
  </head>
  <body class="prose sm:px-20 px-2 pb-20 mt-16">
    <slot />
  </body>
  <style is:global>
    /* Image captions - hug up to images */
    .prose img + em,
    .prose p:has(img) + p > em:only-child {
      display: block;
      text-align: center;
      margin-top: -1rem;
      margin-bottom: 1.5rem;
      font-size: 0.875rem;
      color: #666;
    }
    
    .prose p:has(img) {
      margin-bottom: 0.25rem;
    }
  </style>
</html>
