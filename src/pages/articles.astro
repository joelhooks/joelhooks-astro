---
import {SEO} from "astro-seo"
import { getCollection } from 'astro:content';

const newerPosts = await getCollection('blog');
const olderPosts = await getCollection('legacy_blog');

const allPosts = [
  ...newerPosts.map((post) => {
    return {
      title: post.data.title,
      date: post.data.date,
      description: post.data.description,
      path: `/${post.data.slug || post.id.split('/').pop()?.replace(/\.(md|mdx)$/, '')}`,
    }
  }),
  ...olderPosts.map((post) => {
    const filename = post.id.split('/').pop()?.replace(/\.(md|mdx)$/, '') || '';
    const rawFileSplit = /(\d\d\d\d-\d\d-\d\d)(?:-)(.*)/g.exec(filename);
    const [year, month, day] = rawFileSplit?.[1].split("-") || [];
    return {
      title: post.data.title,
      date: post.data.date,
      description: post.data.description,
      path: `/blog/${year}/${month}/${day}/${rawFileSplit?.[2]}`,
    }
  }),
].sort(function (a, b) {
  return new Date(b.date).getTime() - new Date(a.date).getTime()
})
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEO
      title="articles written by Joel Hooks"
      description="digital garden focused on teaching, technology, and the web"
    />
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <main class="prose sm:px-20 px-2 pb-20">
      {
        allPosts.map((post) => {
          return (
            <article>
              <h2>
                <a href={post.path}>{post.title}</a>
              </h2>
              <p>
                {new Date(post.date).toLocaleDateString("en-us", {
                  weekday: "long",
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </p>
              <p>{post.description}</p>
            </article>
          )
        })
      }
    </main>
  </body>
</html>
