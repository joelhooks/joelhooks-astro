---
import {SEO} from "astro-seo"
import { getCollection, render } from 'astro:content';

export const getStaticPaths = async () => {
  const posts = await getCollection('legacy_blog');

  return posts.map((post) => {
    // Extract date and slug from filename like "2012-07-25-my-post-title"
    const filename = post.id.split('/').pop()?.replace(/\.(md|mdx)$/, '') || '';
    const rawFileSplit = /(\d\d\d\d-\d\d-\d\d)(?:-)(.*)/g.exec(filename);
    const [year, month, day] = rawFileSplit?.[1].split("-") || [];

    return {
      params: {
        slug: rawFileSplit?.[2],
        year,
        month,
        day,
      },
      props: { post, filename },
    };
  });
}

const { post, filename } = Astro.props;
const { Content } = await render(post);
const frontmatter = post.data;

const contentPath = `https://github.com/joelhooks/joelhooks-astro/edit/main/src/content/legacy_blog/${post.id}`
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEO
      title={frontmatter?.title}
      description={frontmatter?.description}
      twitter={{
        card: "summary_large_image",
        site: "@jhooks",
        creator: "@jhooks",
      }}
      openGraph={{
        image: {
          alt: "Joel Hooks",
        },
        basic: {
          title: frontmatter.title,
          type: "article",
          image: `https://joelhooks-opengraph-images.netlify.app/opengraph?title=${encodeURIComponent(
            frontmatter.title
          )}&author=${encodeURIComponent("https://twitter.com/jhooks")}&v=${
            process.env.OG_IMAGE_VERSION
          }`,
        },
        optional: {
          description: frontmatter.description,
        },
      }}
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body>
    <main class="prose sm:px-20 px-2 pb-20">
      <a href="/">Home</a>
      <h1 class="pt-6">{frontmatter.title}</h1>
      <a href={contentPath} rel="nofollow">
        <em>edit ✏️</em>
      </a>
      <Content />
    </main>
  </body>
</html>
